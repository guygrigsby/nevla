import py "builtins"

fn main() (error?) {
    raw := check builtins.bytes([]byte{104, 105})     // round trip through a real python bytes
    got, err := []byte(raw)
    if err != none {
        return err
    }
    print(len(got))          // 2
    print(int(got[0]))       // 104

    ba := check builtins.bytearray(got)
    got2, err2 := []byte(ba)
    print(err2 == none)      // true: bytearray extracts
    print(len(got2))         // 2

    mv := check builtins.memoryview(check builtins.bytes([]byte{9, 8}))
    got3, err3 := []byte(mv)
    print(err3 == none)      // true: memoryview extracts, the third source
    print(int(got3[0]))      // 9

    obj := check builtins.object()
    _, err4 := []byte(obj)
    print(err4 != none)      // true: non buffer object is an error value
    return none
}
